<body>

<div id="score">Score: 0</div>
<div id="startText">TAP TO START</div>

<canvas id="game" width="400" height="600"></canvas>

<script>

const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");

let birdImg = new Image();
birdImg.src = "raven.png";

let bird = {
x:80,
y:200,
width:70,
height:70,
gravity:0.5,
lift:-8,
velocity:0,
rotation:0
};

let pipes=[];
let score=0;
let gameStart=false;

let clouds=[
{x:50,y:80},
{x:200,y:120},
{x:350,y:60}
];

function drawClouds(){

ctx.fillStyle="white";

clouds.forEach(c=>{

ctx.beginPath();
ctx.arc(c.x,c.y,30,0,Math.PI*2);
ctx.fill();

ctx.beginPath();
ctx.arc(c.x+30,c.y+10,25,0,Math.PI*2);
ctx.fill();

ctx.beginPath();
ctx.arc(c.x-30,c.y+10,25,0,Math.PI*2);
ctx.fill();

ctx.beginPath();
ctx.arc(c.x,c.y+15,28,0,Math.PI*2);
ctx.fill();

c.x -= 0.3;

if(c.x < -80){
c.x = 450;
}

});

}

function drawBird(){

ctx.save();

ctx.translate(bird.x + bird.width/2 , bird.y + bird.height/2);
ctx.rotate(bird.rotation);

ctx.drawImage(
birdImg,
-bird.width/2,
-bird.height/2,
bird.width,
bird.height
);

ctx.restore();

}

